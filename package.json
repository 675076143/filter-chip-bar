{
  "name": "filter-chip-bar",
  "version": "0.1.0",
  "description": "搜索即入口 — Headless filter + command palette component for React",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./headless": {
      "types": "./src/headless.ts",
      "import": "./src/headless.ts"
    },
    "./antd6": {
      "types": "./src/adapters/FilterChipBarAntd6.tsx",
      "import": "./src/adapters/FilterChipBarAntd6.tsx"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "oxlint src/",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [
    "react",
    "search",
    "filter",
    "command-palette",
    "headless",
    "antd",
    "shadcn",
    "radix"
  ],
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "peerDependenciesMeta": {
    "antd": {
      "optional": true
    },
    "@ant-design/icons": {
      "optional": true
    }
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-separator": "^1.1.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.0",
    "lucide-react": "^1.21.0",
    "tailwind-merge": "^3.6.0"
  },
  "overrides": {
    "@storybook/builder-vite": {
      "@rollup/pluginutils": "5.1.0"
    }
  },
  "devDependencies": {
    "@ant-design/icons": "^6.0.0",
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/addon-interactions": "^8.6.0",
    "@storybook/builder-vite": "^8.6.18",
    "@storybook/react-vite": "^8.6.0",
    "@tanstack/react-table": "^8.20.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "antd": "^6.0.0",
    "autoprefixer": "^10.5.0",
    "oxlint": "^0.16.0",
    "postcss": "^8.5.15",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "storybook": "^8.6.0",
    "tailwindcss": "^3.4.19",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.21"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js",
        "types": "./dist/index.d.ts"
      },
      "./headless": {
        "import": "./dist/headless.mjs",
        "require": "./dist/headless.js",
        "types": "./dist/headless.d.ts"
      },
      "./antd6": {
        "import": "./dist/adapters/FilterChipBarAntd6.mjs",
        "require": "./dist/adapters/FilterChipBarAntd6.js",
        "types": "./dist/adapters/FilterChipBarAntd6.d.ts"
      }
    }
  }
}
